# --- LLM (OpenRouter) ---
# https://openrouter.ai/keys adresinden al.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter model adlari: https://openrouter.ai/models
LLM_MODEL=openai/gpt-4o-mini

# --- Embedding (lokal BGE-small) ---
# Ilk calistirmada HuggingFace'ten ~120MB indirilir (1-2 dk).
# Turkce desteği BGE-M3 kadar guclu degil ama baslangic icin yeterli.
# Daha iyi Turkce kalitesi icin ileride: intfloat/multilingual-e5-base (~1GB).
BGE_MODEL_NAME=BAAI/bge-small-en-v1.5
BGE_DEVICE=cpu
BGE_MAX_LENGTH=512
BGE_BATCH_SIZE=16

# --- Vector store (Chroma) ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=documents

# --- Chunking (recursive character splitter) ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# --- Upload ---
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=20
