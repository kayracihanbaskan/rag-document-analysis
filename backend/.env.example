# --- Reranker (cross-encoder, lokal) ---
# Retrieve-then-rerank pattern: once 20 chunk al, cross-encoder ile 5'e indir.
# Cross-encoder sorgu + chunk'i BIRLIKTE okur, embedding'den daha kaliteli ama yavas.
# false yaparak devre disi birakabilirsin (graceful fallback cosine-only).
#
# Model secimi:
# - cross-encoder/ms-marco-MiniLM-L-2-v2 (varsayilan): ~278MB, ~50sn ilk indirme, hizli
# - BAAI/bge-reranker-base: ~1.1GB, daha kaliteli ama yavas indirme
# - BAAI/bge-reranker-v2-m3: cok dilli, en kaliteli, ~2.3GB
RERANK_ENABLED=true
RERANK_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-2-v2
RERANK_TOP_K=20     # Chroma'dan ilk aramada bu kadar al
FINAL_TOP_K=5       # LLM'e gonderilecek nihai sayi